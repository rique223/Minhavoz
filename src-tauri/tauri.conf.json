{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "minhavoz",
  "version": "0.1.0",
  "identifier": "com.henrique.minhavoz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "minhavoz",
        "width": 380,
        "height": 520,
        "minWidth": 300,
        "minHeight": 360,
        "maxWidth": 640,
        "maxHeight": 900,
        "resizable": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/piper": "piper",
      "resources/voices": "voices"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
